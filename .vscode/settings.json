{
  // Automatically restart all the other extensions after loading the direnv
  // environment. This way the other extensions will have the environment as well.
  "direnv.restart.automatic": true,
  "editor.defaultFormatter": "maximsmol.vscode-lsp-generic",
  "evenBetterToml.taplo.bundled": false,
  "files.associations": {
    ".envrc": "shellscript",
    "renovate.json": "jsonc",
    "shellcheckrc": "plaintext"
  },
  "fish-lsp.useGlobalExecutable": true,
  "lsp_generic_client.servers": {
    "efm-langserver": {
      "name": "efm-langserver",
      "path": "efm-langserver",
      "args": ["-c", "efm-langserver.yaml"],
      "documentSelector": [{ "pattern": "**", "scheme": "file" }]
    }
  },
  "ltex.completionEnabled": true,
  "ltex.enabled": ["git-commit", "markdown"],
  "Lua.misc.executablePath": "lua-language-server",
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "nixpkgs": { "expr": "import ./nix/packages.nix" },
      "options": {
        "comp_1": {
          "expr": "(import ./.).outputsForCurrentSystem.legacyPackages.homeConfigurations.\"biggs@comp_1\".options"
        }
      }
    }
  },
  "json.schemaDownload.trustedDomains": { "*": true }
}
