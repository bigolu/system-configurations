{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "diagnostics": {
    "unusedLocalExclude": ["_*"],
    "libraryFiles": "Disable"
  },
  "workspace": {
    "library": [
      "$LUA_LS_NVIM_RUNTIME",
      "$LUA_LS_NVIM_PACK",
      "$HOME/.hammerspoon/Spoons/EmmyLua.spoon/annotations"
    ],
    "checkThirdParty": "Disable"
  },
  "runtime": {
    "version": "LuaJIT"
  },
  "telemetry": {
    "enable": false
  },
  "hint": {
    "enable": true
  }
}
