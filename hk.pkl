amends "package://github.com/jdx/hk/releases/download/v1.48.0/hk@1.48.0#/Config.pkl"

local syncs = new Mapping<String, Step | Group> {
  ["direnv"] = new Step {
    glob =
      List(
        "hk.pkl",
        ".envrc-recommended.bash",
        // Everything below affects the nix dev shell, which direnv loads
        "**/*.nix",
        "flake.lock",
        "{nix,mise/tasks}/**/*",
      )
    fix = "direnv reload && direnv exec . true"
  }
  // Use a group so "direnv" is guaranteed to run first and the devshell
  // logs/diff get printed in that step.
  ["sync-2"] = new Group {
    prefix =
      """
      run_in_dev_shell() {
        # when `git-auto-sync` runs, some of the sync jobs may depend on something
        # from the new nix dev shell.
        if [ -n "${git_auto_sync_last_commit:-}" ]; then
          nix run --file . outputsforcurrentsystem.devshells.dev -- "$@"
        else
          "$@"
        fi
      }
      """
        // Concatenate with a single-line string so it doesn't end in a newline.
        + "run_in_dev_shell"
    steps {
      ["system"] = new Step {
        // I want to take input from the user for these reasons:
        //   - So I can input my password for `sudo`, used in the
        //     `hk:system-sync` mise task.
        //   - If the `--ask` flag is passed to the `sync` mise task, then
        //     `hk:system-sync` will prompt the user for confirmation.
        interactive = true
        glob =
          List(
            "hk.pkl",
            "{nix,program-configs}/**/*",
            "**/*.nix",
            "flake.lock",
          )
        fix = "mise run hk:system-sync"
      }
      ["git-auto-sync"] = new Step {
        glob =
          List(
            "hk.pkl",
            "**/*.nix",
            "flake.lock",
          )
        fix = "git-auto-sync install mise run sync"
      }
      ["git-auto-check"] = new Step {
        glob =
          List(
            "hk.pkl",
            "**/*.nix",
            "flake.lock",
          )
        fix = "git-auto-check install mise run check"
      }
    }
  }
}

local nonFormatterFixes = new Mapping<String, Step> {
  ["flake-lock"] = new Step {
    // Ensure a lock is acquired for this file
    glob = "flake.lock"
    fix = "nix flake lock"
  }
  ["readme-config-names"] = new Step {
    // Ensure a lock is acquired for this file
    glob = "README.md"
    fix = "mise run hk:add-config-names-to-readme"
  }
  ["hk-import"] = new Step {
    // Ensure a lock is acquired for this file
    glob = "hk.pkl"
    fix = "mise run hk:update-hk-import"
  }
  ["task-docs"] = new Step {
    // Ensure a lock is acquired for this file
    glob = "docs/tasks.md"
    fix = "mise generate task-docs --style detailed --output docs/tasks.md"
  }
  ["deadnix"] = new Step {
    glob = "**/*.nix"
    fix = "deadnix --quiet --edit {{files}}"
  }
  ["statix-fix"] = new Step {
    glob = "**/*.nix"
    fix = #"for file in {{files}}; do statix fix "$file"; done"#
  }
  ["markdownlint-cli2-fix"] = new Step {
    glob = "**/*.md"
    fix = "markdownlint-cli2 --fix {{files}}"
  }
  ["npins"] = new Step {
    // Ensure a lock is acquired for these files
    glob = "nix/pins/npins/**/*"
    fix = "npins upgrade"
  }
  ["shellcheck-fix"] = new Step {
    glob = "**/*.{sh,bash}"
    fix =
      """
      {
        set +o errexit
        shellcheck --format diff {{files}}
        exit_code=$?
        set -o errexit
        # shellcheck exits with 0 if it does not find any issues and 1 if it
        # does. Any other exit code should be considered a failure.
        if (( exit_code > 1 )); then
          exit 1
        fi
      } |
        git apply --allow-empty
      """
  }
  ["quotes"] = new Step {
    fix = "hk util fix-smart-quotes {{files}}"
  }
  ["end-of-file"] = new Step {
    fix = "hk util end-of-file-fixer --fix {{files}}"
  }
  ["mixed-line-ending"] = new Step {
    fix = "hk util mixed-line-ending --fix {{files}}"
  }
}

local formatterFixes = new Mapping<String, Step> {
  ["taplo-format"] = new Step {
    glob = "**/*.toml"
    fix = "taplo format {{files}}"
  }
  // This also acts a syntax checker for these file types since prettier will
  // fail if the files aren't syntactically correct.
  ["prettier"] = new Step {
    glob = "**/*.{md,json,jsonc,yaml}"
    fix =
      #"""
      prettier \
        --cache \
        --cache-location "$PRJ_DATA_DIR/prettier-cache" \
        --cache-strategy metadata \
        --list-different \
        --write \
        {{files}}
      """#
  }
  ["shfmt"] = new Step {
    glob = "**/*.{sh,bash}"
    fix = "shfmt --write {{files}}"
  }
  ["fish_indent"] = new Step {
    glob = "**/*.fish"
    fix = "fish_indent --write {{files}}"
  }
  ["nixfmt"] = new Step {
    glob = "**/*.nix"
    fix = "nixfmt --strict --verify {{files}}"
  }
  ["stylua"] = new Step {
    glob = "**/*.lua"
    fix = "stylua --verify {{files}}"
  }
  ["pkl-format"] = new Step {
    glob = "hk.pkl"
    fix = "pkl format --write {{files}}"
  }
}

// For `fail_fast` to be effective, steps should be ordered from fastest to
// slowest. Run this command to print the steps sorted by duration:
// `env HK_TIMING_JSON=/dev/stdout hk run fix --all | jq '.steps | to_entries | sort_by(.value.wall_time_ms) | from_entries'`
local checks = new Mapping<String, Step> {
  ["keyd"] = new Step {
    glob = "**/keyd/default.conf"
    check = "type -P keyd >/dev/null && keyd check {{files}}"
  }
  ["actionlint"] = new Step {
    glob = ".github/workflows/*.yaml"
    check = "actionlint {{files}}"
  }
  ["editorconfig-checker"] = new Step {
    check = "editorconfig-checker {{files}}"
  }
  ["fish"] = new Step {
    glob = "**/*.fish"
    check = #"for file in {{files}}; do fish --no-execute "$file"; done"#
  }
  ["large-files"] = new Step {
    check = "hk util check-added-large-files {{files}}"
  }
  ["case-conflict"] = new Step {
    check = "hk util check-case-conflict {{files}}"
  }
  ["nixpkgs-lint"] = new Step {
    glob = "**/*.nix"
    check = "nixpkgs-lint --include-unfinished-lints -- {{files}}"
  }
  ["statix-check"] = new Step {
    glob = "**/*.nix"
    check = #"for file in {{files}}; do statix check "$file"; done"#
  }
  ["shellcheck-check"] = new Step {
    glob = "**/*.{sh,bash}"
    check = "shellcheck {{files}}"
  }
  ["markdownlint-cli2-check"] = new Step {
    glob = "**/*.md"
    check = "markdownlint-cli2 {{files}}"
  }
  ["taplo-lint"] = new Step {
    glob = "**/*.toml"
    check = "taplo lint {{files}}"
  }
  ["pkl-lint"] = new Step {
    glob = "hk.pkl"
    check = "pkl eval {{files}} >/dev/null"
  }
  ["renovate-config-validator"] = new Step {
    glob = "renovate.json"
    check = "renovate-config-validator --no-global --strict {{files}}"
  }
  ["betterleaks"] = new Step {
    check = "betterleaks dir --no-banner --verbose {{files}}"
  }
  ["lua-ls"] = new Step {
    // TODO: Real-Time output only shows if the command is on a single line.
    // This seems like a bug.
    check =
      #"lua-language-server --logpath "$(mktemp --directory)/lua-ls-logs" --check ./program-configs/neovim --configpath "$PWD/.luarc.json""#
  }
  ["nix"] = new Step {
    // TODO: Real-Time output only shows if the command is on a single line.
    // This seems like a bug.
    check =
      #"dest="$PRJ_DATA_DIR/gc-roots/checks"; rm -rf "$dest"; nix build --out-link "$dest/root" --impure --expr "builtins.removeAttrs (import ./.).outputsForCurrentSystem.checks [\"pkgs-shell-bundle\"]""#
  }
}

exclude =
  List(
    ".vscode/ltex*",
    "program-configs/keyboard/US keyboard - no accent keys.bundle",
    "docs",
    "nix/pins/npins",
  )

hooks =
  (
    new Mapping<String, Hook> {
      ["sync"] {
        fix = true
        steps = syncs
      }
      ["fix"] {
        fix = true
        // Ensure our pre-push hook fails, and the push gets aborted, if any
        // files get fixed.
        fail_on_fix = true
        // Non-Formatter fixes must run before formatters since they may produce
        // code that doesn't comply with the formatting.
        steps = (nonFormatterFixes.toMap() + formatterFixes.toMap()).toMapping()
      }
      // We put the checks in a separate hook from the fixes because `hk`
      // doesn't parallelize steps with conflicting globs when `fix = true`,
      // even if those steps only contain `check` commands.
      ["check"] {
        steps = checks
      }
    }
  )
    // Set `shell` and `output_summary` on every step.
    .toMap()
    .mapValues((_, hook) -> (hook) {
      steps =
        hook.steps
          .toMap()
          .mapValues((_, stepOrGroup) -> (stepOrGroup) {
            // To ensure that templates like `{{files}}` are escaped properly
            // for the Bash shell, the last path segment in the first word in
            // `shell` must end in "bash"[1].
            //
            // [1]: https://github.com/jdx/hk/blob/a4f3938616fa64c9d1916fa9681faf5919d77f7f/src/step/runner.rs#L415
            shell = "bash -euo pipefail -c"
          })
          .mapValues((_, stepOrGroup) ->
            if (stepOrGroup is Step)
              (stepOrGroup) { output_summary = "combined" }
            else
              stepOrGroup
          )
          .toMapping()
    })
    .toMapping()
